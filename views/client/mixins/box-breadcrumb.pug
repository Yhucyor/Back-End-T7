mixin box-breadcrumb(breadcrumb)
  .box-breadcrumb
    .inner-image
      img(
        alt=breadcrumb.title
        src=breadcrumb.image
      )
    .inner-content
      .container
        h1.inner-title #{breadcrumb.title}
        .inner-list
          each item in breadcrumb.list
            a(href=item.link) #{item.title}

  // Section 9
  -
    var cityList = [
      {
        id: 1,
        name: "Hà Nội"
      },
      {
        id: 2,
        name: "TP. Hồ Chí Minh"
      },
      {
        id: 3,
        name: "Đà Nẵng"
      },
      {
        id: 4,
        name: "Hải Phòng"
      },
      {
        id: 5,
        name: "Cần Thơ"
      }
    ];

    var categoryDetail = {
      name: "Tour Trong Nước",
      description: `
        Khám phá những điểm đến nổi tiếng trên khắp Việt Nam với nhiều chương trình
        ưu đãi hấp dẫn. Lựa chọn hành trình phù hợp để tận hưởng kỳ nghỉ tuyệt vời
        cùng gia đình và bạn bè.
      `
    };
    var tourList = [
      {
        avatar: "/assets/images/product-1.jpg",
        slug: "#",
        discount: 30,
        name: "Hà Nội - Lào Cai - SaPa 4N3Đ",
        priceAdult: 13650000,
        priceNewAdult: 2590000,
        code: "TOUR000001",
        departureDateFormat: "22/12/2025",
        time: "10 Ngày 9 Đêm",
        ratingStars: 4,
        ratingTotal: 20,
        stockAdult: 10
      },
      {
        avatar: "/assets/images/product-2.jpg",
        slug: "#",
        discount: 25,
        name: "Combo Đà Nẵng - Hội An - Bà Nà Hills",
        priceAdult: 13650000,
        priceNewAdult: 2590000,
        code: "TOUR000002",
        departureDateFormat: "25/12/2025",
        time: "4 Ngày 3 Đêm",
        ratingStars: 5,
        ratingTotal: 35,
        stockAdult: 18
      },
      {
        avatar: "/assets/images/product-3.jpg",
        slug: "#",
        discount: 15,
        name: "Phú Quốc - Thiên Đường Biển Đảo",
        priceAdult: 8500000,
        priceNewAdult: 6900000,
        code: "TOUR000003",
        departureDateFormat: "28/12/2025",
        time: "3 Ngày 2 Đêm",
        ratingStars: 5,
        ratingTotal: 48,
        stockAdult: 12
      }
    ]
  .section-9
    .container
      .inner-wrap
        .inner-left
          // Box Filter
          .box-filter
            .inner-head
              .inner-title Bộ Lọc
              i.fa-solid.fa-filter
            .inner-body
              .inner-group
                .inner-label Điểm đi
                select(name="locationFrom")
                  option(value="") -- Chọn điểm đi --
                  each item in cityList
                    option(value=item.id) #{item.name}
              .inner-group
                .inner-label Điểm đến
                select(name="locationTo")
                  option(value="") -- Chọn điểm đến --
                  each item in cityList
                    option(value=item.name) #{item.name}
              .inner-group
                .inner-label Ngày khởi hành
                input(type="date" name="departureDate")
              .inner-group
                .inner-label Số Lượng Hành Khách
                .inner-input-list
                  .inner-input-item
                    .inner-label Người lớn:
                    input(
                      value="0" 
                      type="number"
                      name="stockAdult"
                      )
                  .inner-input-item
                    .inner-label Trẻ em:
                    input(
                      value="0" 
                      type="number"
                      name="stockChildren"
                      )
                  .inner-input-item
                    .inner-label Em bé:
                    input(
                      value="0" 
                      type="number"
                      name="stockBaby"
                      )
              .inner-group
                .inner-label Mức giá
                select(name="price")
                  option(value="") -- Chọn khoảng giá --
                  option(value="0-999999") Dưới 1tr
                  option(value="1000000-3000000") Từ 1tr đến 3tr
                  option(value="3000000-6000000") Từ 3tr đến 6tr
                  option(value="6000000-10000000") Từ 6tr đến 10tr
                  option(value="10000000-1000000000") Trên 10tr
              .inner-group
                button.inner-button Áp Dụng
          .inner-overlay
          // End Box Filter
        .inner-right
          .inner-info
            h2.inner-title #{categoryDetail.name}
            .inner-desc
              | !{categoryDetail.description}
          .inner-info-2
            .inner-sort
              .inner-label Sắp xếp:
              .inner-list
                button
                  | Giá tăng dần
                  i.fa-solid.fa-square-caret-up
                button
                  | Giá giảm dần
                  i.fa-solid.fa-square-caret-down
                button.active
                  | Khuyến Mại Hot
                  i.fa-solid.fa-tag
                button
                  | Xem Nhiều
                  i.fa-solid.fa-eye
            .inner-count-record
              | Tất cả:
              b 101 Tour
            button.inner-filter-mobile
              span.inner-title Bộ Lọc
              i.fa-solid.fa-filter
          .inner-list-tour
            each item in tourList
              // Product Item
              +product-item(item)
              // End Product Item
          // Pagination
          .box-pagination
            button
              i.fa-solid.fa-angles-left
            button.active 1
            button 2
            button 3
            button 4
            button
              i.fa-solid.fa-angles-right
          // End Pagination
  // End Section 9